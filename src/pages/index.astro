---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
import { sortItemsByDateDesc, withBase } from "../utils/helpers";
import PostCardPreview from "../components/PostCardPreview.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/images/pixeltrue-space-discovery.svg";
import ArrowRight from "../icons/ArrowRight.astro";
import OP_image from "../assets/images/OP01-transparent.png";
import OP_image_vertical from "../assets/images/OP01_2-transparent.png";

const allPosts = (await getCollection("blogs")).sort(sortItemsByDateDesc);
---

<MainLayout activePage="home" pageTitle={"UAMOTORS"}>
  <div
    class="jumbo-banner relative flex flex-col sm:flex-row sm:items-center sm:justify-between w-full px-4 my-12 gap-6"
  >
    <!-- Efecto "Light Blobs" (Nubes espaciales) -->
    <div
      class="absolute top-0 left-0 sm:left-[-10%] w-64 h-64 sm:w-80 sm:h-80 bg-space-red/20 dark:bg-white/10 rounded-full blur-[100px] -z-10 pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 sm:right-[-10%] w-72 h-72 sm:w-96 sm:h-96 bg-space-red/10 dark:bg-white/5 rounded-full blur-[120px] -z-10 pointer-events-none"
    >
    </div>

    <div class="w-full sm:w-fit sm:max-w-1/2 relative z-10">
      {
        siteConfig.hero?.eyebrowText && (
          <span class="tag inline-block mb-2 rounded-full text-sm sm:text-base px-3 py-1 border border-gray-500 kanit-light">
            {siteConfig.hero?.eyebrowText}
          </span>
        )
      }
      <h1 class="sigmar-ff-italic leading-tight text-balance sm:pt-0!">
        {siteConfig.hero?.title}
      </h1>
      <p
        class="kanit-regular text-balance text-base sm:text-lg"
        set:html={siteConfig.hero?.text}
      />
      <div
        class="flex flex-wrap items-center text-xs sm:text-base gap-x-2 gap-y-8 mt-3 sm:mt-12"
      >
        {
          siteConfig.hero?.actions?.map((action, index) => (
            <Button
              href={action.href}
              class={index === 0 ? "space-btn-filled" : "space-btn-outlined"}
            >
              {action.text}
            </Button>
          ))
        }
      </div>
    </div>
    <div class="w-full sm:w-1/2 flex justify-center items-center mt-4 sm:mt-0 relative group">
      
      <!-- Blueprint Grid (Background) -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808020_1px,transparent_1px),linear-gradient(to_bottom,#80808020_1px,transparent_1px)] bg-[size:40px_40px] opacity-40 dark:opacity-20 pointer-events-none rounded-2xl [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)]"></div>

      <!-- Contraluz (Backlighting glow) -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 sm:w-80 sm:h-80 bg-space-red/40 rounded-full blur-[60px] sm:blur-[100px] -z-10 pointer-events-none"></div>

      <!-- Image Wrapper for Laser & Layout -->
      <!-- En móvil, forzamos la altura a 150px para acercarlo a los botones sin afectar el área del láser -->
      <div class="relative w-full h-[150px] sm:h-auto flex justify-center items-center transition-transform duration-700">
        
        <Image
          class="absolute sm:relative w-auto h-auto max-h-[300px] sm:max-h-[650px] object-contain drop-shadow-[0_15px_25px_rgba(0,0,0,0.6)] dark:drop-shadow-[0_15px_25px_rgba(0,0,0,0.8)] -rotate-90 sm:rotate-0"
          src={OP_image_vertical}
          alt={"UAMOTORS Vehicle"}
          transition:name="hero-image"
        />

        <!-- Escáner Láser Animado -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
           <div class="absolute top-0 left-0 w-full h-[2px] bg-space-red shadow-[0_0_20px_5px_rgba(227,30,36,0.8)] animate-laser-scan"></div>
        </div>
        
      </div>
    </div>
  </div>
  <div class="page-content">
    <div
      id="instagram-feed"
      class="flex flex-col items-center justify-center w-full"
    >
      <h2
        class="sigmar-ff text-balance pt-0! pb-8! text-space-red dark:text-space-yellow"
      >
        Síguenos en Instagram
      </h2>

      <div class="w-full max-w-4xl mx-auto mt-4 overflow-hidden">
        <!-- Place <div> tag where you want the feed to appear -->
        <div id="curator-feed-default-feed-layout">
          <a href="https://curator.io" target="_blank" class="crt-logo crt-tag"
            >Powered by Curator.io</a
          >
        </div>

        <!-- The Javascript can be moved to the end of the html page before the </body> tag -->
        <script type="text/javascript" is:inline data-astro-rerun>
          /* curator-feed-default-feed-layout */
          (function () {
            var i,
              e,
              d = document,
              s = "script";
            i = d.createElement("script");
            i.async = 1;
            i.charset = "UTF-8";
            i.src =
              "https://cdn.curator.io/published/a1e46c5e-ad11-49f1-b60c-867fd268c002.js";
            e = d.getElementsByTagName(s)[0];
            e.parentNode.insertBefore(i, e);
          })();
        </script>
      </div>

      <Button
        href="https://www.instagram.com/uamotors.fsae"
        target="_blank"
        class="space-btn-filled mt-8"
      >
        @uamotors.fsae <ArrowRight class="w-5 h-5 fill-current ml-4" />
      </Button>
    </div>
  </div>
</MainLayout>

<style is:global>
  /* 1. ESTADO BASE: Color gris (#434343) para todo el texto y links */
  #curator-feed-default-feed-layout .crt-post-header span,
  #curator-feed-default-feed-layout .crt-post-header a,
  #curator-feed-default-feed-layout .crt-post-header div,
  #curator-feed-default-feed-layout .crt-date,
  #curator-feed-default-feed-layout .crt-post-date,
  #curator-feed-default-feed-layout .crt-time,
  #curator-feed-default-feed-layout a {
    color: #434343 !important;
    opacity: 1 !important;
    text-decoration: none !important;
    transition: color 0.2s ease; /* Para que el cambio al rojo no sea tan brusco */
  }

  /* 2. ESTADO HOVER: Color rojo (#E31E24) al pasar el mouse */
  #curator-feed-default-feed-layout a:hover,
  #curator-feed-default-feed-layout a:hover span,
  #curator-feed-default-feed-layout .crt-post-header a:hover,
  #curator-feed-default-feed-layout .crt-date:hover,
  #curator-feed-default-feed-layout .crt-post-date:hover,
  #curator-feed-default-feed-layout .crt-time:hover {
    color: #e31e24 !important;
    opacity: 1 !important;
  }

  /* 3. Escáner Láser Animación */
  @keyframes laser-scan {
    0% { top: 0%; opacity: 0; }
    5% { opacity: 1; }
    15% { top: 100%; opacity: 1; }
    20% { top: 100%; opacity: 1; }
    30% { top: 0%; opacity: 1; }
    35% { top: 0%; opacity: 0; }
    100% { top: 0%; opacity: 0; }
  }
  .animate-laser-scan {
    opacity: 0;
    animation: laser-scan 12s ease-in-out infinite;
  }
</style>
