---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";
import { sortItemsByDateDesc, withBase } from "../../utils/helpers";
import PostCardPreview from "../../components/PostCardPreview.astro";
import Button from "../../components/Button.astro";
import { Image } from "astro:assets";
import heroImage from "../../assets/images/pixeltrue-space-discovery.svg";
import ArrowRight from "../../icons/ArrowRight.astro";
import OP_image_vertical from "../../assets/images/OP01_2-transparent.png";

const allPosts = (await getCollection("blogs"))
  .filter((post) => post.id.startsWith("en/"))
  .sort(sortItemsByDateDesc);

const enHero = {
  eyebrowText: "UAM | Formula SAE",
  title: "Design with ingenuity, create with passion.",
  text: `More than a racing team, we are a hub of innovation and talent. Join our project and help us push Mexican engineering to the international competition <a href="${withBase('/en/proyecto#formula-sae')}" class="text-space-red font-medium hover:font-bold transition-all">Formula SAE</a>.`,
  actions: [
    {
      text: "View project",
      href: withBase("/en/proyecto")
    },
    {
      text: "Support team",
      href: withBase("/en/nuestros-aliados")
    }
  ]
};
---

<MainLayout activePage="home" pageTitle={siteConfig.title + " | UAM Formula SAE Racing Team"}>
  <div
    class="jumbo-banner relative flex flex-col sm:flex-row sm:items-center sm:justify-between w-full px-4 my-12 gap-6"
  >
    <div
      class="absolute top-0 left-0 sm:left-[-10%] w-64 h-64 sm:w-80 sm:h-80 bg-space-red/20 dark:bg-white/10 rounded-full blur-[100px] -z-10 pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 sm:right-[-10%] w-72 h-72 sm:w-96 sm:h-96 bg-space-red/10 dark:bg-white/5 rounded-full blur-[120px] -z-10 pointer-events-none"
    >
    </div>

    <div class="w-full sm:flex-1 min-w-0 relative z-30">
      {
        enHero.eyebrowText && (
          <span
            id="hero-eyebrow-text"
            class="tag inline-block mb-2 rounded-full text-sm sm:text-base px-3 py-1 border border-gray-500 kanit-light select-none cursor-pointer"
            style="touch-action: manipulation;"
          >
            {enHero.eyebrowText}
          </span>
        )
      }
      <h1 class="sigmar-ff-italic leading-tight text-balance sm:pt-0!">
        {enHero.title}
      </h1>
      <p
        class="kanit-regular text-balance text-base sm:text-lg"
        set:html={enHero.text}
      />
      <div
        class="flex flex-wrap items-center text-xs sm:text-base gap-3 mt-3 sm:mt-12"
      >
        {
          enHero.actions.map((action, index) => (
            <Button
              href={action.href}
              class={index === 0 ? "space-btn-filled" : "space-btn-outlined"}
            >
              {action.text}
            </Button>
          ))
        }
      </div>
    </div>
    <div
      class="w-full sm:flex-1 min-w-0 flex justify-center items-center mt-4 sm:mt-0 relative group"
    >
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:40px_40px] opacity-15 dark:opacity-25 pointer-events-none rounded-2xl [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)]"
      >
      </div>

      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 sm:w-80 sm:h-80 bg-space-red/40 rounded-full blur-[60px] sm:blur-[100px] -z-10 pointer-events-none"
      >
      </div>

      <div
        class="relative w-full h-[150px] sm:h-auto flex justify-center items-center transition-transform duration-700"
      >
        <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
          <div
            class="absolute bottom-0 left-0 w-full h-[2px] bg-space-red shadow-[0_0_20px_5px_rgba(227,30,36,0.8)] animate-laser-scan-reverse"
          >
          </div>
        </div>

        <div
          class="absolute sm:relative z-10 animate-car-levitate flex justify-center items-center"
        >
          <Image
            class="w-auto h-auto max-h-[300px] sm:max-h-[650px] object-contain drop-shadow-[0_15px_25px_rgba(0,0,0,0.6)] dark:drop-shadow-[0_15px_25px_rgba(0,0,0,0.8)] -rotate-90 sm:rotate-0 rounded-4xl"
            src={OP_image_vertical}
            alt={"UAMOTORS Vehicle"}
            transition:name="hero-image"
          />
        </div>

        <div class="absolute inset-0 pointer-events-none overflow-hidden z-20">
          <div
            class="absolute top-0 left-0 w-full h-[2px] bg-[#9b0c10] shadow-[0_0_20px_5px_rgba(155,12,16,0.8)] animate-laser-scan"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="page-content">
    <div
      class="flex flex-col items-center justify-center w-full"
    >
      <h2
        class="sigmar-ff text-balance pt-0! pb-8! text-space-red dark:text-space-yellow"
      >
        Follow us on Instagram!
      </h2>

      <div class="w-full max-w-4xl mx-auto mt-4 overflow-hidden">
        <div id="curator-feed-default-feed-layout">
          <a href="https://curator.io" target="_blank" class="crt-logo crt-tag"
            >Powered by Curator.io</a
          >
        </div>

        <script type="text/javascript" is:inline data-astro-rerun>
          (function () {
            var i,
              e,
              d = document,
              s = "script";
            i = d.createElement("script");
            i.async = 1;
            i.charset = "UTF-8";
            i.src =
              "https://cdn.curator.io/published/a1e46c5e-ad11-49f1-b60c-867fd268c002.js";
            e = d.getElementsByTagName(s)[0];
            e.parentNode.insertBefore(i, e);
          })();
        </script>
      </div>

      <Button
        href="https://www.instagram.com/uamotors.fsae"
        target="_blank"
        class="space-btn-filled mt-8"
      >
        @uamotors.fsae <ArrowRight class="w-5 h-5 fill-current ml-4" />
      </Button>
    </div>
  </div>
</MainLayout>

<style is:global>
  html.splash-active .animate-laser-scan,
  html.splash-active .animate-laser-scan-reverse {
    animation: none !important;
    opacity: 0 !important;
  }
  html.splash-active .animate-car-levitate {
    animation: none !important;
  }

  .crt-popup {
    background-color: var(--glass-bg) !important;
    backdrop-filter: var(--glass-blur) !important;
    -webkit-backdrop-filter: var(--glass-blur) !important;
    color: #434343 !important;
    border-radius: 8px !important;
    border: var(--glass-border) !important;
    box-shadow: var(--glass-shadow) !important;
    overflow: hidden !important;
  }

  .crt-popup .crt-video-container,
  .crt-popup .crt-image-container,
  .crt-popup .crt-post-image,
  .crt-popup img,
  .crt-popup video {
    border-radius: 8px !important;
  }

  .crt-popup .crt-video-container,
  .crt-popup .crt-image-container,
  .crt-popup .crt-post-image,
  .crt-popup .crt-popup-left {
    background-color: transparent !important;
    backdrop-filter: none !important;
  }

  #curator-feed-default-feed-layout .crt-post,
  #curator-feed-default-feed-layout .crt-post-c {
    border-radius: 12px !important;
    overflow: hidden !important;
    background-color: transparent !important;
  }

  #curator-feed-default-feed-layout .crt-post-hover {
    background-color: rgba(255, 255, 255, 0.48) !important;
    backdrop-filter: var(--glass-blur) !important;
    -webkit-backdrop-filter: var(--glass-blur) !important;
  }

  #curator-feed-default-feed-layout .crt-post-hover .crt-post-footer {
    background-color: transparent !important;
    border-top: none !important;
  }

  .crt-no-touch .crt-grid-post:not(.crt-post-youtube) .crt-post-hover:after,
  .crt-no-touch .crt-grid-post:not(.crt-post-youtube) .crt-post-hover:before,
  #curator-feed-default-feed-layout .crt-post-hover:after,
  #curator-feed-default-feed-layout .crt-post-hover:before,
  .crt-post-hover:after,
  .crt-post-hover:before,
  .crt-post-hover .crt-post-text:after,
  .crt-post-hover .crt-post-text-wrap:after,
  .crt-grid-post .crt-post-hover:after {
    background: none !important;
    background-image: none !important;
    content: none !important;
    display: none !important;
  }

  #curator-feed-default-feed-layout .crt-social-icon,
  #curator-feed-default-feed-layout .crt-social-icon i,
  #curator-feed-default-feed-layout .crt-social-icon svg {
    color: #1a1a1a !important;
    fill: #1a1a1a !important;
    opacity: 0.95 !important;
  }

  #curator-feed-default-feed-layout .crt-post-hover .crt-post-text,
  #curator-feed-default-feed-layout .crt-post-hover .crt-post-text p,
  #curator-feed-default-feed-layout .crt-post-hover .crt-post-text a,
  #curator-feed-default-feed-layout .crt-post-hover .crt-post-fullname,
  #curator-feed-default-feed-layout .crt-post-hover .crt-post-date,
  #curator-feed-default-feed-layout .crt-post-hover .crt-post-date-link,
  #curator-feed-default-feed-layout .crt-post-hover .crt-post-share p,
  #curator-feed-default-feed-layout .crt-post-hover a,
  #curator-feed-default-feed-layout .crt-post-hover span {
    color: #1a1a1a !important;
  }

  #curator-feed-default-feed-layout .crt-post-image,
  #curator-feed-default-feed-layout .crt-post img {
    border-radius: 12px !important;
  }

  #curator-feed-default-feed-layout .crt-post-header span,
  #curator-feed-default-feed-layout .crt-post-header a,
  #curator-feed-default-feed-layout .crt-post-header div,
  #curator-feed-default-feed-layout .crt-date,
  #curator-feed-default-feed-layout .crt-post-date,
  #curator-feed-default-feed-layout .crt-time,
  #curator-feed-default-feed-layout a,
  .crt-popup .crt-post-header span,
  .crt-popup .crt-post-header a,
  .crt-popup .crt-post-header div,
  .crt-popup .crt-author-name,
  .crt-popup .crt-post-content-text,
  .crt-popup .crt-date,
  .crt-popup .crt-post-date,
  .crt-popup .crt-time,
  .crt-popup a {
    color: #1a1a1a !important;
    opacity: 1 !important;
    text-decoration: none !important;
    transition: color 0.2s ease !important;
  }

  #curator-feed-default-feed-layout a:hover,
  #curator-feed-default-feed-layout a:hover span,
  #curator-feed-default-feed-layout .crt-post-header a:hover,
  #curator-feed-default-feed-layout .crt-date:hover,
  #curator-feed-default-feed-layout .crt-post-date:hover,
  #curator-feed-default-feed-layout .crt-time:hover,
  .crt-popup a:hover,
  .crt-popup a:hover span,
  .crt-popup .crt-author-name:hover {
    color: #e31e24 !important;
  }

  .crt-popup .crt-close,
  .crt-popup .crt-play,
  .crt-popup .crt-nav-left,
  .crt-popup .crt-nav-right,
  .crt-popup .crt-icon-close {
    color: #1a1a1a !important;
    background-color: transparent !important;
  }

  .crt-popup .crt-close:hover,
  .crt-popup .crt-nav-left:hover,
  .crt-popup .crt-nav-right:hover {
    color: #e31e24 !important;
  }

  html.dark .crt-popup {
    background-color: var(--glass-bg) !important;
    backdrop-filter: var(--glass-blur) !important;
    -webkit-backdrop-filter: var(--glass-blur) !important;
    color: #f5f5f5 !important;
    border: var(--glass-border) !important;
    box-shadow: var(--glass-shadow) !important;
  }

  html.dark #curator-feed-default-feed-layout .crt-post-hover {
    background-color: rgba(0, 0, 0, 0.55) !important;
    backdrop-filter: var(--glass-blur) !important;
    -webkit-backdrop-filter: var(--glass-blur) !important;
  }

  html.dark #curator-feed-default-feed-layout .crt-post-hover .crt-post-text,
  html.dark #curator-feed-default-feed-layout .crt-post-hover .crt-post-text p,
  html.dark #curator-feed-default-feed-layout .crt-post-hover .crt-post-text a,
  html.dark #curator-feed-default-feed-layout .crt-post-hover .crt-post-fullname,
  html.dark #curator-feed-default-feed-layout .crt-post-hover .crt-post-date,
  html.dark #curator-feed-default-feed-layout .crt-post-hover .crt-post-date-link,
  html.dark #curator-feed-default-feed-layout .crt-post-hover .crt-post-share p,
  html.dark #curator-feed-default-feed-layout .crt-post-hover a,
  html.dark #curator-feed-default-feed-layout .crt-post-hover span {
    color: #f5f5f5 !important;
  }

  html.dark #curator-feed-default-feed-layout .crt-social-icon,
  html.dark #curator-feed-default-feed-layout .crt-social-icon i,
  html.dark #curator-feed-default-feed-layout .crt-social-icon svg {
    color: #f5f5f5 !important;
    fill: #f5f5f5 !important;
    opacity: 0.9 !important;
  }

  html.dark #curator-feed-default-feed-layout .crt-post-header span,
  html.dark #curator-feed-default-feed-layout .crt-post-header a,
  html.dark #curator-feed-default-feed-layout .crt-post-header div,
  html.dark #curator-feed-default-feed-layout .crt-date,
  html.dark #curator-feed-default-feed-layout .crt-post-date,
  html.dark #curator-feed-default-feed-layout .crt-time,
  html.dark #curator-feed-default-feed-layout a,
  html.dark .crt-popup .crt-post-header span,
  html.dark .crt-popup .crt-post-header a,
  html.dark .crt-popup .crt-post-header div,
  html.dark .crt-popup .crt-author-name,
  html.dark .crt-popup .crt-post-content-text,
  html.dark .crt-popup .crt-date,
  html.dark .crt-popup .crt-post-date,
  html.dark .crt-popup .crt-time,
  html.dark .crt-popup a {
    color: #f5f5f5 !important;
  }

  html.dark #curator-feed-default-feed-layout a:hover,
  html.dark #curator-feed-default-feed-layout a:hover span,
  html.dark #curator-feed-default-feed-layout .crt-post-header a:hover,
  html.dark #curator-feed-default-feed-layout .crt-date:hover,
  html.dark #curator-feed-default-feed-layout .crt-post-date:hover,
  html.dark #curator-feed-default-feed-layout .crt-time:hover,
  html.dark .crt-popup a:hover,
  html.dark .crt-popup a:hover span,
  html.dark .crt-popup .crt-author-name:hover {
    color: #ff4046 !important;
  }

  html.dark .crt-popup .crt-close,
  html.dark .crt-popup .crt-play,
  html.dark .crt-popup .crt-nav-left,
  html.dark .crt-popup .crt-nav-right,
  html.dark .crt-popup .crt-icon-close {
    color: #f5f5f5 !important;
  }

  html.dark .crt-popup .crt-close:hover,
  html.dark .crt-popup .crt-nav-left:hover,
  html.dark .crt-popup .crt-nav-right:hover {
    color: #ff4046 !important;
  }

  .crt-popup-wrapper .crt-popup .crt-previous,
  .crt-popup-wrapper .crt-popup .crt-next {
    z-index: 999999 !important;
  }

  @keyframes laser-scan-v4 {
    0% {
      top: 0%;
      opacity: 0;
      transform: scaleX(0);
    }
    2% {
      top: 0%;
      opacity: 1;
      transform: scaleX(1);
    }
    15% {
      top: 100%;
      opacity: 1;
      transform: scaleX(1);
    }
    20% {
      top: 100%;
      opacity: 1;
      transform: scaleX(1);
    }
    33% {
      top: 0%;
      opacity: 1;
      transform: scaleX(1);
    }
    35% {
      top: 0%;
      opacity: 0;
      transform: scaleX(0);
    }
    100% {
      top: 0%;
      opacity: 0;
      transform: scaleX(0);
    }
  }
  @keyframes laser-scan-reverse-v4 {
    0% {
      bottom: 0%;
      opacity: 0;
      transform: scaleX(0);
    }
    2% {
      bottom: 0%;
      opacity: 1;
      transform: scaleX(1);
    }
    15% {
      bottom: 100%;
      opacity: 1;
      transform: scaleX(1);
    }
    20% {
      bottom: 100%;
      opacity: 1;
      transform: scaleX(1);
    }
    33% {
      bottom: 0%;
      opacity: 1;
      transform: scaleX(1);
    }
    35% {
      bottom: 0%;
      opacity: 0;
      transform: scaleX(0);
    }
    100% {
      bottom: 0%;
      opacity: 0;
      transform: scaleX(0);
    }
  }
  .animate-laser-scan {
    opacity: 0;
    transform: scaleX(0);
    animation: laser-scan-v4 12s ease-in-out infinite;
    will-change: top, opacity, transform;
  }
  .animate-laser-scan-reverse {
    opacity: 0;
    transform: scaleX(0);
    animation: laser-scan-reverse-v4 12s ease-in-out infinite;
    will-change: bottom, opacity, transform;
  }

  @media (max-width: 639px) {
    @keyframes laser-scan-mobile-v3 {
      0% {
        left: 0%;
        opacity: 0;
        transform: scaleY(0);
      }
      2% {
        left: 0%;
        opacity: 1;
        transform: scaleY(1);
      }
      15% {
        left: 100%;
        opacity: 1;
        transform: scaleY(1);
      }
      20% {
        left: 100%;
        opacity: 1;
        transform: scaleY(1);
      }
      33% {
        left: 0%;
        opacity: 1;
        transform: scaleY(1);
      }
      35% {
        left: 0%;
        opacity: 0;
        transform: scaleY(0);
      }
      100% {
        left: 0%;
        opacity: 0;
        transform: scaleY(0);
      }
    }
    @keyframes laser-scan-reverse-mobile-v3 {
      0% {
        left: 100%;
        opacity: 0;
        transform: scaleY(0);
      }
      2% {
        left: 100%;
        opacity: 1;
        transform: scaleY(1);
      }
      15% {
        left: 0%;
        opacity: 1;
        transform: scaleY(1);
      }
      20% {
        left: 0%;
        opacity: 1;
        transform: scaleY(1);
      }
      33% {
        left: 100%;
        opacity: 1;
        transform: scaleY(1);
      }
      35% {
        left: 100%;
        opacity: 0;
        transform: scaleY(0);
      }
      100% {
        left: 100%;
        opacity: 0;
        transform: scaleY(0);
      }
    }
    .animate-laser-scan {
      width: 2px !important;
      height: 100% !important;
      transform: scaleY(0);
      animation: laser-scan-mobile-v3 12s ease-in-out infinite !important;
      will-change: left, opacity, transform !important;
    }
    .animate-laser-scan-reverse {
      width: 2px !important;
      height: 100% !important;
      top: 0 !important;
      bottom: auto !important;

      transform: scaleY(0);
      animation: laser-scan-reverse-mobile-v3 12s ease-in-out infinite !important;
      will-change: left, opacity, transform !important;
    }
  }

  body {
    overflow-x: clip;
  }

  @keyframes car-levitate-v2 {
    0% {
      transform: scale(1);
    }
    2% {
      transform: scale(1.05);
    }
    33% {
      transform: scale(1.05);
    }
    35% {
      transform: scale(1);
    }
    100% {
      transform: scale(1);
    }
  }
  .animate-car-levitate {
    animation: car-levitate-v2 12s ease-in-out infinite;
    will-change: transform;
  }
</style>
