---
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";
import Shield from "../../icons/assets/Shield.astro";
import Gear from "../../icons/assets/Gear.astro";
import Chart from "../../icons/assets/Chart.astro";
import Electronics from "../../icons/assets/Electronics.astro";
import Wind from "../../icons/assets/Wind.astro";
import PowerTrain from "../../icons/assets/powertrain-icon.astro";
import RacingCar from "../../icons/assets/RacingCar.astro";
import Chart2 from "../../icons/assets/Chart2.astro";
import RaceFlag from "../../icons/assets/RaceFlag.astro";
import OP_image from "../../assets/images/OP01-transparent-soft.png";
import Dynamics from "../../icons/assets/dynamics-icon.astro";
---

<MainLayout
  activePage="proyecto"
  pageTitle={siteConfig.title + " | Project"}
  description="Explore the technical details of the OP01, the UAMOTORS race car designed under Formula SAE regulations. Learn about the chassis, suspension, aerodynamics, and powertrain."
>
  <div class="page-content max-w-4xl mx-auto">
    <h1 class="sigmar-ff text-balance mb-8">The "OP" Project</h1>

    <div class="relative w-full flex justify-center items-center mb-6">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 sm:w-96 sm:h-96 bg-space-red/30 dark:bg-space-red/40 rounded-full blur-[60px] sm:blur-[100px] -z-10 pointer-events-none"
      >
      </div>

      <div class="w-full drop-shadow-[0_15px_25px_rgba(0,0,0,0.6)] dark:drop-shadow-[0_20px_30px_rgba(0,0,0,0.9)] z-10">
        <Image
          width={1024}
          loading="eager"
          class="mx-auto block w-full h-auto max-h-[380px] object-contain pb-8"
          src={OP_image}
          alt="OP01 Prototype"
          transition:name="hero-image"
        />
      </div>
    </div>

    <section class="text-left space-y-16">
      <div>
        <h2
          class="sigmar-ff text-3xl mb-4 text-space-red dark:text-space-yellow"
        >
          Technical Vision
        </h2>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed">
          The <strong>UAMOTORS</strong> racing project takes shape in <strong>"OP"</strong>, our flagship single-seater. This vehicle is the result of an engineering cycle that spans <strong>conception</strong>, <strong>design</strong>, <strong>manufacturing</strong>, and <strong>testing</strong> under international standards. The goal behind <strong>"OP"</strong> is to build a reliable race car optimized for novice drivers, prioritizing low operating costs and highly manufacturable designs.
        </p>
      </div>

      <div>
        <h3 class="sigmar-ff text-2xl mb-6">Design Objectives</h3>
        <ul class="space-y-6 kanit-light text-lg sm:text-xl">
          <li class="flex items-start gap-4">
            <Shield class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong
                class="kanit-regular text-space-red dark:text-space-yellow"
                >Safety:</strong
              ><br />
              Prioritize driver integrity and the vehicle's structural safety at all times.
            </div>
          </li>
          <li class="flex items-start gap-4">
            <Gear class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong
                class="kanit-regular text-space-red dark:text-space-yellow"
                >Reliability:</strong
              ><br />
              Ensure the consistency of integrated systems to pass technical inspections.
            </div>
          </li>
          <li class="flex items-start gap-4">
            <Chart class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong
                class="kanit-regular text-space-red dark:text-space-yellow"
                >Data-Driven Development:</strong
              ><br />
              Implement a robust data acquisition system (telemetry) to serve as a technical foundation for the team's future development.
            </div>
          </li>
        </ul>
      </div>

      <div>
        <h2
          class="sigmar-ff text-3xl mb-4 text-space-red dark:text-space-yellow"
        >
          Vehicle Systems
        </h2>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed mb-6">
          The development of the <strong>OP</strong> is divided into interconnected technical areas working together to maximize performance:
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-6">
          <div
            class="md:col-span-1 lg:col-span-3 bg-black/5 dark:bg-white/5 p-6 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4 class="sigmar-ff text-xl mb-2 flex items-center gap-2">
              <RacingCar class="w-6 h-6 shrink-0" /> Chassis
            </h4>
            <p class="kanit-light text-base sm:text-lg">
              Structural design and dynamic validation of the space frame chassis and bodywork. Its goal is to guarantee driver safety and vehicle integrity.
            </p>
          </div>
          <div
            class="md:col-span-1 lg:col-span-3 bg-black/5 dark:bg-white/5 p-6 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4 class="sigmar-ff text-xl mb-2 flex items-center gap-2">
              <Dynamics class="w-6 h-6 shrink-0" /> Dynamics
            </h4>
            <p class="kanit-light text-base sm:text-lg">
              Responsible for on-track vehicle behavior through the precise tuning of the suspension and steering systems, ensuring agile, stable handling and mechanical grip.
            </p>
          </div>
          <div
            class="md:col-span-1 lg:col-span-2 bg-black/5 dark:bg-white/5 p-6 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4 class="sigmar-ff text-xl mb-2 flex items-center gap-2">
              <PowerTrain class="w-6 h-6 shrink-0" /> Powertrain
            </h4>
            <p class="kanit-light text-base sm:text-lg">
              Integration, thermal management, and calibration of the powertrain based on a high-performance motorcycle engine. Designing intake, exhaust, and drivetrain systems to optimize power delivery and on-track traction.
            </p>
          </div>
          <div
            class="md:col-span-1 lg:col-span-2 bg-black/5 dark:bg-white/5 p-6 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4 class="sigmar-ff text-xl mb-2 flex items-center gap-2">
              <Electronics class="w-6 h-6 shrink-0" /> Electronics
            </h4>
            <p class="kanit-light text-base sm:text-lg">
              Programming of the <span class="relative group cursor-help"
                ><strong>ECU</strong><span
                  class="pointer-events-none absolute bottom-full left-1/2 z-20 mb-2 w-44 -translate-x-1/2 rounded-xl border border-black/10 bg-neutral-900/95 p-2 text-center text-xs leading-normal text-white opacity-0 shadow-xl transition-opacity duration-200 group-hover:opacity-100 dark:border-white/10 dark:bg-neutral-950/95 kanit-regular"
                  >Engine Control Unit</span
                ></span
              >, integration of embedded systems and dynamic sensors. Responsible for vehicle electronics, power delivery, and data acquisition (DAQ) for technical feedback.
            </p>
          </div>
          <div
            class="md:col-span-2 lg:col-span-2 bg-black/5 dark:bg-white/5 p-6 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4 class="sigmar-ff text-xl mb-2 flex items-center gap-2">
              <Wind class="w-6 h-6 shrink-0" /> Aerodynamics
            </h4>
            <p class="kanit-light text-base sm:text-lg">
              Airflow optimization using <span class="relative group cursor-help"
                ><strong>CFD</strong><span
                  class="pointer-events-none absolute bottom-full left-1/2 z-20 mb-2 w-48 -translate-x-1/2 rounded-xl border border-black/10 bg-neutral-900/95 p-2 text-center text-xs leading-normal text-white opacity-0 shadow-xl transition-opacity duration-200 group-hover:opacity-100 dark:border-white/10 dark:bg-neutral-950/95 kanit-regular"
                  >Computational Fluid Dynamics</span
                ></span
              > to generate efficient downforce, enhancing race car stability without compromising performance through excessive drag.
            </p>
          </div>
        </div>
      </div>

      <div class="pt-8 md:pt-12">
        <h3 class="sigmar-ff text-2xl mb-6">Tools & Validation</h3>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed mb-6">
          To guarantee the precision of every component, the team utilizes industry-standard tools for design and simulation:
        </p>
        <ul class="space-y-4 kanit-light text-lg sm:text-xl">
          <li>
            <strong class="kanit-regular text-space-red dark:text-space-yellow"
              >CAD Design:</strong
            > Extensive use of <a
              href="https://www.solidworks.com/"
              target="_blank"><strong>Solidworks</strong></a
            > for mechanical modeling.
          </li>
          <li>
            <strong class="kanit-regular text-space-red dark:text-space-yellow"
              >Simulation:</strong
            > Structural and fluid analysis using <a
              href="https://www.ansys.com/"
              target="_blank"><strong>Ansys</strong></a
            >.
          </li>
          <li>
            <strong class="kanit-regular text-space-red dark:text-space-yellow"
              >Manufacturing:</strong
            > Process planning with <a
              href="/en/nuestros-aliados/#nuestros-aliados"
              ><strong>strategic partners</strong></a
            > to ensure the technical viability of the components.
          </li>
        </ul>
      </div>

      <div id="formula-sae">
        <h2
          class="sigmar-ff text-3xl mb-4 text-space-red dark:text-space-yellow"
        >
          What is Formula SAE?
        </h2>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed mb-8">
          <strong><a href="https://www.fsaeonline.com/" target="_blank" class=""
              >Formula SAE (FSAE)</a
            ></strong> is the most globally recognized student engineering competition, governed by the technical standards of the <strong><a href="https://www.sae.org/" target="_blank" class=""
              >Society of Automotive Engineers (SAE)</a
            ></strong>. It is not simply a speed competition, but a platform where over 100 universities validate the design, manufacturing, and financial management of a high-performance race car.
        </p>
        <div>
          <h3 class="sigmar-ff text-2xl mb-6">Evaluation Criteria</h3>
          <ul
            class="grid grid-cols-1 md:grid-cols-2 gap-8 gap-y-12 kanit-light text-lg sm:text-xl"
          >
            <li class="flex items-start gap-4">
              <Chart2 class="w-8 h-8 shrink-0 mt-1" />
              <div>
                <strong
                  class="kanit-regular text-space-red dark:text-space-yellow"
                  >Static Events</strong>
                <ul class="mt-3 space-y-3 text-base sm:text-lg">
                  <li>
                    <strong>Engineering design:</strong> Technical defense of design decisions before industry expert judges.
                  </li>
                  <li>
                    <strong>Cost analysis:</strong> Evaluation of resource efficiency and manufacturing processes.
                  </li>
                  <li>
                    <strong>Business Presentation:</strong> Presenting a market strategy and business viability for serial production.
                  </li>
                </ul>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <RaceFlag class="w-8 h-8 shrink-0 mt-1" />
              <div>
                <strong
                  class="kanit-regular text-space-red dark:text-space-yellow"
                  >Dynamic Events</strong>
                <ul class="mt-3 space-y-3 text-base sm:text-lg">
                  <li>
                    <strong>Acceleration:</strong> Evaluation of power and traction over a 75-meter straight.
                  </li>
                  <li>
                    <strong>Skidpad:</strong> Measuring cornering ability and lateral grip on a figure-eight track.
                  </li>
                  <li>
                    <strong>Autocross:</strong> Assessing handling and agility on a tight, winding circuit.
                  </li>
                  <li>
                    <strong>Endurance:</strong> A demanding 22 km race to test overall reliability and efficiency.
                  </li>
                </ul>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <div class="bg-gray-100 dark:bg-gray-800 p-8 rounded-3xl">
        <h2
          class="sigmar-ff text-3xl mb-4 text-space-red dark:text-space-yellow"
        >
          FSAE Michigan 2027 Roadmap
        </h2>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed mb-8">
          The project operates under a defined timeline focused on the team's continuous growth:
        </p>
        <div class="pl-8 space-y-0 relative">
          <div class="relative pb-8 timeline-item" data-date="2025-03">
            <div
              class="absolute left-[-26px] top-1.5 bottom-0 w-1 bg-gray-300 dark:bg-gray-600 timeline-line"
            >
            </div>
            <div
              class="absolute -left-[32px] top-1.5 h-4 w-4 rounded-full border-2 border-gray-300 bg-white dark:border-gray-600 dark:bg-gray-800 timeline-dot transition-all duration-300"
            >
            </div>
            <h4 class="sigmar-ff text-xl timeline-title">
              Founding (March 2025)
            </h4>
            <p class="kanit-light text-lg timeline-desc">
              Start of conceptual design and formation of the multidisciplinary team.
            </p>
          </div>

          <div class="relative pb-8 timeline-item" data-date="2026-09">
            <div
              class="absolute left-[-26px] top-1.5 bottom-0 w-1 bg-gray-300 dark:bg-gray-600 timeline-line"
            >
            </div>
            <div
              class="absolute -left-[32px] top-1.5 h-4 w-4 rounded-full border-2 border-gray-300 bg-white dark:border-gray-600 dark:bg-gray-800 timeline-dot transition-all duration-300"
            >
            </div>
            <h4 class="sigmar-ff text-xl timeline-title">
              FSAE México (September 2026)
            </h4>
            <p class="kanit-light text-lg timeline-desc">
              Participation in design and simulation categories, without the physical prototype requirement.
            </p>
          </div>

          <div class="relative pb-8 timeline-item" data-date="2027-02">
            <div
              class="absolute left-[-26px] top-1.5 bottom-0 w-1 bg-gray-300 dark:bg-gray-600 timeline-line"
            >
            </div>
            <div
              class="absolute -left-[32px] top-1.5 h-4 w-4 rounded-full border-2 border-gray-300 bg-white dark:border-gray-600 dark:bg-gray-800 timeline-dot transition-all duration-300"
            >
            </div>
            <h4 class="sigmar-ff text-xl timeline-title">
              FSAE México (February 2027)
            </h4>
            <p class="kanit-light text-lg timeline-desc">
              Participation in FSAE México with the physical prototype and dynamic tests.
            </p>
          </div>

          <div class="relative timeline-item" data-date="2027-05">
            <div
              class="absolute -left-[32px] top-1.5 h-4 w-4 rounded-full border-2 border-gray-300 bg-white dark:border-gray-600 dark:bg-gray-800 timeline-dot transition-all duration-300"
            >
            </div>
            <h4 class="sigmar-ff text-xl timeline-title">
              FSAE Michigan (May 2027)
            </h4>
            <p class="kanit-light text-lg timeline-desc">
              Goal of qualifying and competing in the international event in the United States.
            </p>
          </div>
        </div>

        <script>
          function initTimeline() {
            const items = document.querySelectorAll(".timeline-item");
            if (items.length === 0) return;

            const now = new Date();
            const currentYear = now.getFullYear();
            const currentMonth = now.getMonth();

            items.forEach((item, index) => {
              const dateStr = item.getAttribute("data-date");
              if (!dateStr) return;

              const [year, month] = dateStr.split("-").map(Number);

              const isCompleted =
                currentYear > year ||
                (currentYear === year && currentMonth >= month - 1);

              const dot = item.querySelector(".timeline-dot");
              const line = item.querySelector(".timeline-line");

              if (isCompleted) {
                dot.classList.remove(
                  "border-gray-300",
                  "dark:border-gray-600",
                  "bg-white",
                  "dark:bg-gray-800",
                );
                dot.classList.add("bg-space-red", "border-space-red");

                if (line) {
                  const nextItem = items[index + 1];
                  let nextCompleted = false;
                  if (nextItem) {
                    const nextDateStr = nextItem.getAttribute("data-date");
                    if (nextDateStr) {
                      const [ny, nm] = nextDateStr.split("-").map(Number);
                      nextCompleted =
                        currentYear > ny ||
                        (currentYear === ny && currentMonth >= nm - 1);
                    }
                  }

                  if (nextCompleted) {
                    line.classList.remove("bg-gray-300", "dark:bg-gray-600");
                    line.classList.add("bg-space-red");
                  } else {
                    line.classList.remove("bg-gray-300", "dark:bg-gray-600");
                    line.classList.add(
                      "bg-gradient-to-b",
                      "from-space-red",
                      "to-gray-300",
                      "dark:to-gray-600",
                    );
                  }
                }
              } else {
                dot.classList.remove("bg-space-red", "border-space-red");
                dot.classList.add(
                  "border-gray-300",
                  "dark:border-gray-600",
                  "bg-white",
                  "dark:bg-gray-800",
                );

                if (line) {
                  line.classList.remove(
                    "bg-space-red",
                    "bg-gradient-to-b",
                    "from-space-red",
                    "to-gray-300",
                    "dark:to-gray-600",
                  );
                  line.classList.add("bg-gray-300", "dark:bg-gray-600");
                }
              }
            });
          }

          initTimeline();

          document.addEventListener("swup:content:replace", initTimeline);
          document.addEventListener("astro:page-load", initTimeline);
        </script>
      </div>
    </section>
  </div>
</MainLayout>
