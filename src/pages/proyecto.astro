---
import { Image } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
import Shield from "../icons/assets/Shield.astro";
import Gear from "../icons/assets/Gear.astro";
import Chart from "../icons/assets/Chart.astro";
import Electronics from "../icons/assets/Electronics.astro";
import Wind from "../icons/assets/Wind.astro";
import PowerTrain from "../icons/assets/powertrain-icon.astro";
import RacingCar from "../icons/assets/RacingCar.astro";
import Chart2 from "../icons/assets/Chart2.astro";
import RaceFlag from "../icons/assets/RaceFlag.astro";
import OP_image from "../assets/images/OP01-transparent-soft.png";
import Dynamics from "../icons/assets/dynamics-icon.astro";
---

<MainLayout
  activePage="proyecto"
  pageTitle={siteConfig.title + " | Proyecto"}
  description="Explora los detalles técnicos del OP01, el monoplaza de UAMOTORS diseñado bajo normas de Formula SAE. Conoce el chasis, suspensión, aerodinámica y tren motriz."
>
  <div class="page-content max-w-4xl mx-auto">
    <h1 class="sigmar-ff text-balance mb-8">El Proyecto "OP"</h1>

    <div class="relative w-full flex justify-center items-center mb-6">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 sm:w-96 sm:h-96 bg-space-red/30 dark:bg-space-red/40 rounded-full blur-[60px] sm:blur-[100px] -z-10 pointer-events-none"
      >
      </div>

      <div class="w-full drop-shadow-[0_15px_25px_rgba(0,0,0,0.6)] dark:drop-shadow-[0_20px_30px_rgba(0,0,0,0.9)] z-10">
        <Image
          width={1024}
          loading="eager"
          class="mx-auto block w-full h-auto max-h-[380px] object-contain pb-8"
          src={OP_image}
          alt="Prototipo OP01"
          transition:name="hero-image"
        />
      </div>
    </div>

    <section class="text-left space-y-16">
      <div>
        <h2
          class="sigmar-ff text-3xl mb-4 text-space-red dark:text-space-yellow"
        >
          Visión Técnica
        </h2>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed">
          El proyecto de escudería de <strong>UAMOTORS</strong>, se materializa
          en <strong>"OP"</strong>, nuestro monoplaza insignia. Este vehículo es
          el resultado de un ciclo de ingeniería que abarca <strong
            >concepción</strong
          >, <strong>diseño</strong>,
          <strong>fabricación</strong> y <strong>presentación</strong> bajo normas
          internacionales. El objetivo detrás de <strong>"OP"</strong> es consolidar
          un monoplaza fiable y optimizado para pilotos principiantes, priorizando
          bajos costos operativos y diseños altamente manufacturables.
        </p>
      </div>

      <div>
        <h3 class="sigmar-ff text-2xl mb-6">Objetivos de Diseño</h3>
        <ul class="space-y-6 kanit-light text-lg sm:text-xl">
          <li class="flex items-start gap-4">
            <Shield class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong
                class="kanit-regular text-space-red dark:text-space-yellow"
                >Seguridad:</strong
              ><br />
              Priorizar la integridad del piloto y la seguridad estructural del vehículo
              en todo momento.
            </div>
          </li>
          <li class="flex items-start gap-4">
            <Gear class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong
                class="kanit-regular text-space-red dark:text-space-yellow"
                >Confiabilidad:</strong
              ><br />
              Asegurar la consistencia de los sistemas integrados para cumplir con
              las pruebas técnicas (tech inspection).
            </div>
          </li>
          <li class="flex items-start gap-4">
            <Chart class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong
                class="kanit-regular text-space-red dark:text-space-yellow"
                >Desarrollo Basado en Datos:</strong
              ><br />
              Implementar un sistema robusto de recolección de datos (telemetría)
              como base técnica para futuras evoluciones del equipo.
            </div>
          </li>
        </ul>
      </div>

      <div>
        <h2
          class="sigmar-ff text-3xl mb-4 text-space-red dark:text-space-yellow"
        >
          Sistemas del Vehículo
        </h2>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed mb-6">
          El desarrollo del <strong>OP</strong> se divide en áreas técnicas interconectadas
          que trabajan en conjunto para maximizar el rendimiento:
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-6">
          <div
            class="md:col-span-1 lg:col-span-3 bg-black/5 dark:bg-white/5 p-6 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4 class="sigmar-ff text-xl mb-2 flex items-center gap-2">
              <RacingCar class="w-6 h-6 shrink-0" /> Chassis
            </h4>
            <p class="kanit-light text-base sm:text-lg">
              Diseño estructural y validación dinámica del chasis tubular y la
              carrocería. Su objetivo es garantizar la máxima seguridad del
              piloto y la integridad del vehículo.
            </p>
          </div>
          <div
            class="md:col-span-1 lg:col-span-3 bg-black/5 dark:bg-white/5 p-6 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4 class="sigmar-ff text-xl mb-2 flex items-center gap-2">
              <Dynamics class="w-6 h-6 shrink-0" /> Dynamics
            </h4>
            <p class="kanit-light text-base sm:text-lg">
              Responsable del comportamiento físico en pista mediante el ajuste
              preciso de la suspensión y dirección, garantizando un manejo ágil,
              estable y una excelente tracción mecánica.
            </p>
          </div>
          <div
            class="md:col-span-1 lg:col-span-2 bg-black/5 dark:bg-white/5 p-6 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4 class="sigmar-ff text-xl mb-2 flex items-center gap-2">
              <PowerTrain class="w-6 h-6 shrink-0" /> Powertrain
            </h4>
            <p class="kanit-light text-base sm:text-lg">
              Integración, gestión térmica y calibración del tren motriz basado
              en un motor de motocicleta de alto rendimiento. Diseña los
              sistemas de admisión, escape y transmisión, enfocándose en
              optimizar la entrega de potencia y la tracción en pista.
            </p>
          </div>
          <div
            class="md:col-span-1 lg:col-span-2 bg-black/5 dark:bg-white/5 p-6 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4 class="sigmar-ff text-xl mb-2 flex items-center gap-2">
              <Electronics class="w-6 h-6 shrink-0" /> Electronics
            </h4>
            <p class="kanit-light text-base sm:text-lg">
              Programación de la <span class="relative group cursor-help"
                ><strong>ECU</strong><span
                  class="pointer-events-none absolute bottom-full left-1/2 z-20 mb-2 w-44 -translate-x-1/2 rounded-xl border border-black/10 bg-neutral-900/95 p-2 text-center text-xs leading-normal text-white opacity-0 shadow-xl transition-opacity duration-200 group-hover:opacity-100 dark:border-white/10 dark:bg-neutral-950/95 kanit-regular"
                  >Unidad de Control del Motor</span
                ></span
              >, integración de sistemas embebidos y sensores dinámicos. Se
              encarga de la gestión electrónica del vehículo, el control de
              potencia y la adquisición de datos (DAQ) para retroalimentación
              técnica.
            </p>
          </div>
          <div
            class="md:col-span-2 lg:col-span-2 bg-black/5 dark:bg-white/5 p-6 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4 class="sigmar-ff text-xl mb-2 flex items-center gap-2">
              <Wind class="w-6 h-6 shrink-0" /> Aerodynamics
            </h4>
            <p class="kanit-light text-base sm:text-lg">
              Optimización del flujo de aire mediante <span
                class="relative group cursor-help"
                ><strong>CFD</strong><span
                  class="pointer-events-none absolute bottom-full left-1/2 z-20 mb-2 w-48 -translate-x-1/2 rounded-xl border border-black/10 bg-neutral-900/95 p-2 text-center text-xs leading-normal text-white opacity-0 shadow-xl transition-opacity duration-200 group-hover:opacity-100 dark:border-white/10 dark:bg-neutral-950/95 kanit-regular"
                  >Dinámica de Fluidos Computacional</span
                ></span
              > para generar carga aerodinámica (downforce) eficiente, mejorando la
              estabilidad del monoplaza sin comprometer el desempeño por arrastre
              excesivo.
            </p>
          </div>
        </div>
      </div>

      <div class="pt-8 md:pt-12">
        <h3 class="sigmar-ff text-2xl mb-6">Herramientas y Validación</h3>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed mb-6">
          Para garantizar la precisión de cada componente, el equipo utiliza
          herramientas de nivel industrial para simulaciones y diseño:
        </p>
        <ul class="space-y-4 kanit-light text-lg sm:text-xl">
          <li>
            <strong class="kanit-regular text-space-red dark:text-space-yellow"
              >Diseño CAD:</strong
            > Uso extensivo de <a
              href="https://www.solidworks.com/"
              target="_blank"><strong>Solidworks</strong></a
            > para el modelado mecánico.
          </li>
          <li>
            <strong class="kanit-regular text-space-red dark:text-space-yellow"
              >Simulación:</strong
            > Análisis estructural y de fluidos mediante <a
              href="https://www.ansys.com/"
              target="_blank"><strong>Ansys</strong></a
            >.
          </li>
          <li>
            <strong class="kanit-regular text-space-red dark:text-space-yellow"
              >Manufactura:</strong
            > Planificación de procesos con <a
              href="/nuestros-aliados/#nuestros-aliados"
              ><strong>aliados estratégicos</strong></a
            > para asegurar la viabilidad técnica de los componentes.
          </li>
        </ul>
      </div>

      <div id="formula-sae">
        <h2
          class="sigmar-ff text-3xl mb-4 text-space-red dark:text-space-yellow"
        >
          ¿Qué es Fórmula SAE?
        </h2>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed mb-8">
          <strong
            ><a href="https://www.fsaeonline.com/" target="_blank" class=""
              >Fórmula SAE (FSAE)</a
            ></strong
          > es la competencia de ingeniería automotriz con mayor reconocimiento internacional,
          regida por los estándares técnicos de la
          <strong
            ><a href="https://www.sae.org/" target="_blank" class=""
              >Society of Automotive Engineers (SAE)</a
            ></strong
          >. No es sólo una competencia de velocidad, sino una plataforma donde
          más de 100 universidades validan el diseño, la manufactura y la
          gestión financiera de un monoplaza de alto rendimiento.
        </p>
        <div>
          <h3 class="sigmar-ff text-2xl mb-6">Criterios de Evaluación</h3>
          <ul
            class="grid grid-cols-1 md:grid-cols-2 gap-8 gap-y-12 kanit-light text-lg sm:text-xl"
          >
            <li class="flex items-start gap-4">
              <Chart2 class="w-8 h-8 shrink-0 mt-1" />
              <div>
                <strong
                  class="kanit-regular text-space-red dark:text-space-yellow"
                  >Pruebas Estáticas</strong
                >
                <ul class="mt-3 space-y-3 text-base sm:text-lg">
                  <li>
                    <strong>Diseño de ingeniería:</strong> Defensa técnica de cada
                    decisión tomada ante jueces expertos.
                  </li>
                  <li>
                    <strong>Análisis de costos:</strong> Evaluación de la eficiencia
                    en el uso de recursos y procesos de manufactura.
                  </li>
                  <li>
                    <strong>Plan de negocios:</strong> Presentación de una estrategia
                    de mercado y viabilidad para producción en serie.
                  </li>
                </ul>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <RaceFlag class="w-8 h-8 shrink-0 mt-1" />
              <div>
                <strong
                  class="kanit-regular text-space-red dark:text-space-yellow"
                  >Pruebas Dinámicas</strong
                >
                <ul class="mt-3 space-y-3 text-base sm:text-lg">
                  <li>
                    <strong>Aceleración:</strong> Prueba de potencia y tracción en
                    una recta de 75 metros.
                  </li>
                  <li>
                    <strong>Skidpad:</strong> Medición de fuerza centrífuga y agarre
                    lateral en curvas.
                  </li>
                  <li>
                    <strong>Autocross:</strong> Evaluación de agilidad y maniobrabilidad
                    en circuitos revirados.
                  </li>
                  <li>
                    <strong>Endurance:</strong> Reto de resistencia de 22 km para
                    probar fiabilidad y eficiencia.
                  </li>
                </ul>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <div class="bg-gray-100 dark:bg-gray-800 p-8 rounded-3xl">
        <h2
          class="sigmar-ff text-3xl mb-4 text-space-red dark:text-space-yellow"
        >
          Ruta FSAE Michigan 2027
        </h2>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed mb-8">
          El proyecto tiene una línea de tiempo definida que busca el
          crecimiento constante del equipo:
        </p>
        <div class="pl-8 space-y-0 relative">
          <div class="relative pb-8 timeline-item" data-date="2025-03">
            <div
              class="absolute left-[-26px] top-1.5 bottom-0 w-1 bg-gray-300 dark:bg-gray-600 timeline-line"
            >
            </div>
            <div
              class="absolute -left-[32px] top-1.5 h-4 w-4 rounded-full border-2 border-gray-300 bg-white dark:border-gray-600 dark:bg-gray-800 timeline-dot transition-all duration-300"
            >
            </div>
            <h4 class="sigmar-ff text-xl timeline-title">
              Fundación (Marzo 2025)
            </h4>
            <p class="kanit-light text-lg timeline-desc">
              Inicio del diseño conceptual y formación del equipo
              multidisciplinario.
            </p>
          </div>

          <div class="relative pb-8 timeline-item" data-date="2026-09">
            <div
              class="absolute left-[-26px] top-1.5 bottom-0 w-1 bg-gray-300 dark:bg-gray-600 timeline-line"
            >
            </div>
            <div
              class="absolute -left-[32px] top-1.5 h-4 w-4 rounded-full border-2 border-gray-300 bg-white dark:border-gray-600 dark:bg-gray-800 timeline-dot transition-all duration-300"
            >
            </div>
            <h4 class="sigmar-ff text-xl timeline-title">
              FSAE México (Septiembre 2026)
            </h4>
            <p class="kanit-light text-lg timeline-desc">
              Participación en categoría de diseño y simulaciones, sin
              requerimiento de prototipo físico.
            </p>
          </div>

          <div class="relative pb-8 timeline-item" data-date="2027-02">
            <div
              class="absolute left-[-26px] top-1.5 bottom-0 w-1 bg-gray-300 dark:bg-gray-600 timeline-line"
            >
            </div>
            <div
              class="absolute -left-[32px] top-1.5 h-4 w-4 rounded-full border-2 border-gray-300 bg-white dark:border-gray-600 dark:bg-gray-800 timeline-dot transition-all duration-300"
            >
            </div>
            <h4 class="sigmar-ff text-xl timeline-title">
              FSAE México (Febrero 2027)
            </h4>
            <p class="kanit-light text-lg timeline-desc">
              Participación en FSAE México con el prototipo físico y pruebas
              dinámicas.
            </p>
          </div>

          <div class="relative timeline-item" data-date="2027-05">
            <div
              class="absolute -left-[32px] top-1.5 h-4 w-4 rounded-full border-2 border-gray-300 bg-white dark:border-gray-600 dark:bg-gray-800 timeline-dot transition-all duration-300"
            >
            </div>
            <h4 class="sigmar-ff text-xl timeline-title">
              FSAE Michigan (Mayo 2027)
            </h4>
            <p class="kanit-light text-lg timeline-desc">
              Meta de clasificación y competencia internacional en Estados
              Unidos.
            </p>
          </div>
        </div>

        <script>
          function initTimeline() {
            const items = document.querySelectorAll(".timeline-item");
            if (items.length === 0) return;

            const now = new Date();
            const currentYear = now.getFullYear();
            const currentMonth = now.getMonth();

            items.forEach((item, index) => {
              const dateStr = item.getAttribute("data-date");
              if (!dateStr) return;

              const [year, month] = dateStr.split("-").map(Number);

              const isCompleted =
                currentYear > year ||
                (currentYear === year && currentMonth >= month - 1);

              const dot = item.querySelector(".timeline-dot");
              const line = item.querySelector(".timeline-line");

              if (isCompleted) {
                dot.classList.remove(
                  "border-gray-300",
                  "dark:border-gray-600",
                  "bg-white",
                  "dark:bg-gray-800",
                );
                dot.classList.add("bg-space-red", "border-space-red");

                if (line) {
                  const nextItem = items[index + 1];
                  let nextCompleted = false;
                  if (nextItem) {
                    const nextDateStr = nextItem.getAttribute("data-date");
                    if (nextDateStr) {
                      const [ny, nm] = nextDateStr.split("-").map(Number);
                      nextCompleted =
                        currentYear > ny ||
                        (currentYear === ny && currentMonth >= nm - 1);
                    }
                  }

                  if (nextCompleted) {
                    line.classList.remove("bg-gray-300", "dark:bg-gray-600");
                    line.classList.add("bg-space-red");
                  } else {
                    line.classList.remove("bg-gray-300", "dark:bg-gray-600");
                    line.classList.add(
                      "bg-gradient-to-b",
                      "from-space-red",
                      "to-gray-300",
                      "dark:to-gray-600",
                    );
                  }
                }
              } else {
                dot.classList.remove("bg-space-red", "border-space-red");
                dot.classList.add(
                  "border-gray-300",
                  "dark:border-gray-600",
                  "bg-white",
                  "dark:bg-gray-800",
                );

                if (line) {
                  line.classList.remove(
                    "bg-space-red",
                    "bg-gradient-to-b",
                    "from-space-red",
                    "to-gray-300",
                    "dark:to-gray-600",
                  );
                  line.classList.add("bg-gray-300", "dark:bg-gray-600");
                }
              }
            });
          }

          initTimeline();

          document.addEventListener("swup:content:replace", initTimeline);
          document.addEventListener("astro:page-load", initTimeline);
        </script>
      </div>
    </section>
  </div>
</MainLayout>
