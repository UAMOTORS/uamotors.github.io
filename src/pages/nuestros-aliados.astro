---
import { Image } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
// import LogoCarousel from "../components/LogoCarousel.astro";
import siteConfig from "../site.config";
import EmailIcon from "../icons/social_media/Email.astro";
import Eyes from "../icons/assets/Eyes.astro";
import Mobile from "../icons/assets/Mobile.astro";
import Document from "../icons/assets/Document.astro";
import Event from "../icons/assets/Event.astro";
// import TiraUamotors from "../components/TiraUamotors.astro";
// import logo1 from "../assets/logos/logo-1.png";
// import logo2 from "../assets/logos/logo-2.jpg";

// logos diamante/diamond
import LogoFuam from "../components/logos/diamond/LogoFuam.astro";
import LogoGeely from "../components/logos/diamond/LogoGeely.astro";

// logos oro/gold
import LogoSolidworks from "../components/logos/gold/LogoSolidworks.astro";
import LogoAnsys from "../components/logos/gold/LogoAnsys.astro";
import LogoEsss from "../components/logos/gold/LogoEsss.astro";
import LogoRapidHarnest from "../components/logos/gold/LogoRapidHarnest.astro";

// logos plata/silver
import LogoDitsa from "../components/logos/silver/LogoDitsa.astro";
import LogoPrimeraPlus from "../components/logos/silver/LogoPrimeraPlus.astro";
import LogoDepartamentoEnergia from "../components/logos/silver/LogoDepartamentoEnergia.astro";

// logos bronce/bronze
import LogoEscuadronUam from "../components/logos/bronze/LogoEscuadronUam.astro";
---

<MainLayout
  activePage="nuestros aliados"
  pageTitle={siteConfig.title + " | Nuestros Aliados"}
>
  <div class="page-content max-w-3xl mx-auto min-w-0">
    <h1 class="sigmar-ff text-balance mb-8">Nuestros Aliados</h1>

    <section id="nuestros-aliados" class="text-left space-y-16">
      <div class="space-y-20">
        {/* Fila 1: Diamante */}
        <div id="diamante-grid" class="w-full">
          <div
            class="grid grid-cols-1 sm:grid-cols-2 gap-8 sm:gap-6 md:gap-12 items-center max-w-3xl mx-auto"
          >
            <div class="h-14 sm:h-18 w-full flex items-center justify-center">
              <a
                href="https://www.geelymexico.com/"
                target="_blank"
                class="h-full w-56 sm:w-72 flex items-center justify-center"
              >
                <LogoGeely class="h-full w-full object-contain" />
              </a>
            </div>
            <div class="h-14 sm:h-18 w-full flex items-center justify-center">
              <a
                href="https://www.fundacionuam.org/"
                target="_blank"
                class="h-full w-56 sm:w-72 flex items-center justify-center"
              >
                <LogoFuam class="h-full w-full object-contain" />
              </a>
            </div>
          </div>
        </div>

        {/* Fila 2: Oro */}
        <div id="oro-grid" class="w-full">
          <div
            class="grid grid-cols-2 md:grid-cols-4 gap-8 sm:gap-6 md:gap-12 items-center max-w-3xl mx-auto"
          >
            <div class="h-12 sm:h-16 w-full flex items-center justify-center">
              <a
                href="https://www.solidworks.com/"
                target="_blank"
                class="h-full w-full max-w-[140px] sm:max-w-[160px] flex items-center justify-center"
              >
                <LogoSolidworks class="max-h-full max-w-full object-contain" />
              </a>
            </div>
            <div class="h-12 sm:h-16 w-full flex items-center justify-center">
              <a
                href="https://www.ansys.com/"
                target="_blank"
                class="h-full w-full max-w-[140px] sm:max-w-[160px] flex items-center justify-center"
              >
                <LogoAnsys class="max-h-full max-w-full object-contain" />
              </a>
            </div>
            <div class="h-12 sm:h-16 w-full flex items-center justify-center">
              <a
                href="https://www.esss.com/es/"
                target="_blank"
                class="h-full w-full max-w-[140px] sm:max-w-[160px] flex items-center justify-center"
              >
                <LogoEsss class="max-h-full max-w-full object-contain" />
              </a>
            </div>
            <div class="h-12 sm:h-16 w-full flex items-center justify-center">
              <a
                href="https://www.rapidharness.com/"
                target="_blank"
                class="h-full w-full max-w-[140px] sm:max-w-[160px] flex items-center justify-center"
              >
                <LogoRapidHarnest
                  class="max-h-full max-w-full object-contain"
                />
              </a>
            </div>
          </div>
        </div>

        {/* Fila 3: Plata y Bronce */}
        <div id="plata-bronce-grid" class="w-full">
          <div
            class="grid grid-cols-2 md:grid-cols-4 gap-8 sm:gap-6 md:gap-12 items-center max-w-3xl mx-auto"
          >
            <div class="h-12 sm:h-16 w-full flex items-center justify-center">
              <a
                href="http://fenix.uam.mx/escuadron_uam/"
                target="_blank"
                class="h-full w-full max-w-[120px] sm:max-w-[140px] flex items-center justify-center"
              >
                <LogoEscuadronUam
                  class="max-h-full max-w-full object-contain"
                />
              </a>
            </div>
            <div class="h-12 sm:h-16 w-full flex items-center justify-center">
              <a
                href="https://ditsa.com.mx/"
                target="_blank"
                class="h-full w-full max-w-[120px] sm:max-w-[140px] flex items-center justify-center"
              >
                <LogoDitsa class="max-h-full max-w-full object-contain" />
              </a>
            </div>
            <div class="h-12 sm:h-16 w-full flex items-center justify-center">
              <a
                href="https://www.primeraplus.com.mx/"
                target="_blank"
                class="h-full w-full max-w-[120px] sm:max-w-[140px] flex items-center justify-center"
              >
                <LogoPrimeraPlus class="max-h-full max-w-full object-contain" />
              </a>
            </div>
            <div class="h-12 sm:h-16 w-full flex items-center justify-center">
              <a
                href="https://energia.azc.uam.mx/en/"
                target="_blank"
                class="h-full w-full max-w-[120px] sm:max-w-[140px] flex items-center justify-center"
              >
                <LogoDepartamentoEnergia
                  class="max-h-full max-w-full object-contain"
                />
              </a>
            </div>
          </div>
        </div>
      </div>
      <div>
        <p
          class="kanit-light text-lg sm:text-xl leading-relaxed mb-8 text-center sm:text-left"
        >
          <strong>UAMOTORS</strong> es una iniciativa que busca demostrar el alto
          nivel de la
          <a href="https://www.azc.uam.mx/" target="_blank">
            <strong>UAM Azcapotzalco</strong></a
          > en escenarios tecnológicos globales. Para materializar nuestra visión
          y llevar la ingeniería mexicana al límite, buscamos aliados estratégicos
          que nos brinden el <strong>respaldo técnico y financiero</strong> necesario
          para convertir este desarrollo en una realidad competitiva.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div
            class="bg-black/5 dark:bg-white/5 p-8 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4
              class="sigmar-ff text-xl mb-3 text-space-red dark:text-space-yellow"
            >
              Alianza Estratégica
            </h4>
            <p class="kanit-light text-base sm:text-lg leading-relaxed">
              No buscamos solo un patrocinador, sino un aliado estratégico que
              impulse el crecimiento del talento estudiantil y fortalezca el
              desarrollo tecnológico de México.
            </p>
          </div>
          <div
            class="bg-black/5 dark:bg-white/5 p-8 rounded-3xl border border-black/10 dark:border-white/10 hover:-translate-y-2 hover:bg-black/10 dark:hover:bg-white/10 transition-all duration-300"
          >
            <h4
              class="sigmar-ff text-xl mb-3 text-space-red dark:text-space-yellow"
            >
              Vínculo Academia-Industria
            </h4>
            <p class="kanit-light text-base sm:text-lg leading-relaxed">
              El proyecto posiciona a las empresas como impulsoras del talento
              joven, brindando una plataforma de vinculación directa con la
              comunidad universitaria de la <a
                href="https://www.azc.uam.mx/"
                target="_blank"><strong>UAM Azcapotzalco</strong></a
              >.
            </p>
          </div>
        </div>
      </div>

      <div>
        <h2
          class="sigmar-ff text-3xl mb-8 text-space-red dark:text-space-yellow"
        >
          Beneficios Clave
        </h2>
        <ul
          class="grid grid-cols-1 md:grid-cols-2 gap-8 gap-y-12 kanit-light text-lg sm:text-xl"
        >
          <li class="flex items-start gap-4">
            <Eyes class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong
                class="kanit-regular text-space-red dark:text-space-yellow"
                >Visibilidad de Marca:</strong
              ><br />
              Presencia de logotipos en nuestro monoplaza <a href="/proyecto"
                ><strong>"OP"</strong></a
              >, uniformes y material promocional.
            </div>
          </li>
          <li class="flex items-start gap-4">
            <Mobile class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong
                class="kanit-regular text-space-red dark:text-space-yellow"
                >Impacto Digital:</strong
              ><br />
              Difusión constante en <a href="/contacto/#canales-oficiales"
                ><strong>plataformas sociales</strong></a
              > con un alcance dinámico en continúo crecimiento.
            </div>
          </li>
          <li class="flex items-start gap-4">
            <Document class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong
                class="kanit-regular text-space-red dark:text-space-yellow"
                >Beneficio Fiscal:</strong
              ><br />
              Entrega de comprobante fiscal deducible de impuestos con el respaldo
              de <a href="https://www.fundacionuam.org/" target="_blank"
                ><strong>Fundación UAM</strong></a
              >.
            </div>
          </li>
          <li class="flex items-start gap-4">
            <Event class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong
                class="kanit-regular text-space-red dark:text-space-yellow"
                >Presencia en Eventos:</strong
              ><br />
              Exposición de la marca en actividades con la comunidad universitaria
              y exposiciones automotrices.
            </div>
          </li>
        </ul>
      </div>

      <div
        id="unete"
        class="bg-space-red/10 dark:bg-space-yellow/10 p-8 sm:p-12 rounded-3xl text-center border border-space-red/20 dark:border-space-yellow/20"
      >
        <h2
          class="sigmar-ff text-3xl sm:text-4xl mb-4 text-space-red dark:text-space-yellow"
        >
          ¡Acelera nuestra meta!
        </h2>
        <p
          class="kanit-light text-lg sm:text-xl leading-relaxed mb-8 max-w-2xl mx-auto opacity-90"
        >
          Tu respaldo es el motor que nos permite llevar la ingeniería de la <a
            href="https://www.azc.uam.mx/"><strong>UAM Azcapotzalco</strong></a
          > al siguiente nivel. Para conocer nuestros esquemas de colaboración y sus
          <strong>beneficios</strong>, contactános y trabajemos en una alianza.
        </p>
        <div
          class="mt-8 pt-8 border-t border-space-red/20 dark:border-white/10 flex flex-col sm:flex-row justify-center gap-6 sm:gap-12 kanit-light text-lg"
        >
          <a
            href="mailto:uamotors.fsae@azc.uam.mx?subject=Interés%20en%20Propuesta%20de%20Patrocinio"
            class="flex items-center justify-center gap-2 hover:text-space-red dark:hover:text-space-yellow transition-colors group"
          >
            <EmailIcon class="w-5 h-5" /> uamotors.fsae@azc.uam.mx
          </a>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<style is:global>
  #diamante-grid img,
  #oro-grid img,
  #plata-bronce-grid img {
    border-radius: 0 !important;
  }
</style>
