---
import { Image } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import LogoCarousel from "../components/LogoCarousel.astro";
import siteConfig from "../site.config";
import EmailIcon from "../icons/social_media/Email.astro";
import Eyes from "../icons/assets/Eyes.astro";
import Mobile from "../icons/assets/Mobile.astro";
import Document from "../icons/assets/Document.astro";
import Event from "../icons/assets/Event.astro";
import Pdf from "../icons/assets/Pdf.astro";
import LogoUamotors from "../assets/logos/logo-uamotors.png"
import logo1 from "../assets/logos/logo-1.png";
import logo2 from "../assets/logos/logo-2.jpg";
import logo3 from "../assets/logos/logo-3.jpg";
import logo4 from "../assets/logos/logo-4.png";
import logo5 from "../assets/logos/logo-5.png";
import logo6 from "../assets/logos/logo-6.png";
import logo7 from "../assets/logos/logo-7.jpg";
import logo8 from "../assets/logos/logo-8.jpg";
import logo9 from "../assets/logos/logo-9.webp";
import logo10 from "../assets/logos/logo-10.webp";
import logo11 from "../assets/logos/logo-11.jpeg";
import logoFuam from "../assets/logos/logo-fuam.svg";
import logoGeely from "../assets/logos/logo-geely.svg";
import LocationPin from "../icons/assets/LocationPin.astro";
---

<MainLayout activePage="patrocinadores" pageTitle={siteConfig.title + " | Patrocinadores"}>
  <div class="page-content max-w-3xl mx-auto min-w-0">
    <h1 class="sigmar-ff text-balance mb-8">Patrocinadores</h1>

    <section class="text-left space-y-16">
      
      <div>
        <h2 class="sigmar-ff text-3xl mb-4 text-space-red dark:text-space-yellow">Nuestros Aliados</h2>
        <!-- Placeholder para la galería de logos -->

        <div id="diamante-grid" class="mt-8 w-full">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 sm:gap-6 md:gap-12 items-center max-w-2xl mx-auto">
            <!-- <div class="h-8 sm:h-10 w-full flex items-center justify-center">
              <Image 
                src={LogoUamotors} 
                alt="UAMOTORS" 
                height={40}
                class="h-full w-40 object-contain" 
              />
            </div> -->
            <div class="h-8 sm:h-10 w-full flex items-center justify-center">
              <a href="https://www.geelymexico.com/" target="_blank">
                <Image 
                  src={logoGeely} 
                  alt="Geely" 
                  height={40}
                  class="h-full w-40 object-contain dark:brightness-0 dark:invert transition-all" 
                />
              </a>
            </div>
            <div class="h-8 sm:h-10 w-full flex items-center justify-center">
              <a href="https://www.fundacionuam.org/" target="_blank">
                <Image 
                  src={logoFuam} 
                  alt="Fundación UAM" 
                  height={40}
                  class="h-full w-40 object-contain" 
                />
              </a>
            </div>
          </div>
        </div>

        <!-- Patrocinadores Oro -->
        <div id="carousel-oro" class="mt-8 border-black/20 dark:border-white/20 rounded-3xl p-6 sm:p-12 overflow-hidden w-full relative" style="contain: content;">
          <LogoCarousel>
            <Image src={LogoUamotors} alt="UAMOTORS" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo1} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo2} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo3} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo4} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo5} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo6} alt="Socio" height={40} class="h-10 w-auto object-contain" />
          </LogoCarousel>
        </div>

        <!-- Patrocinadores Bronce & Plata-->
        <div id="carousel-bronce-plata" class="mt-8 border-black/20 dark:border-white/20 rounded-3xl p-6 sm:p-12 overflow-hidden w-full relative" style="contain: content;">
          <LogoCarousel>
            <!-- <Image src={LogoUamotors} alt="UAMOTORS" height={40} class="h-10 w-auto object-contain" /> -->
            <Image src={logo1} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo2} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo3} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo4} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo5} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo6} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo7} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo8} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo9} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo10} alt="Socio" height={40} class="h-10 w-auto object-contain" />
            <Image src={logo11} alt="Socio" height={40} class="h-10 w-auto object-contain" />
          </LogoCarousel>
        </div>

      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 bg-black/5 dark:bg-white/5 p-8 rounded-3xl border border-black/10 dark:border-white/10">
        <div class="md:col-span-2">
           <p class="kanit-light text-center text-base sm:text-lg mb-4 text-black/60 dark:text-white/60"><strong>UAMOTORS</strong> es una iniciativa que busca desafiar las habilidades de sus integrantes para demostrar que el nivel de la <a href="https://www.azc.uam.mx/" target="_blank"><strong>UAM Azcapotzalco</strong></a> permite afrontar exitosamente retos de desarrollo tecnológico en competencias internacionales.</p>
        </div>
        <div>
          <h4 class="sigmar-ff text-xl mb-3 text-space-red dark:text-space-yellow">Alianza Estratégica</h4>
          <p class="kanit-light text-base sm:text-lg leading-relaxed">
            No buscamos solo un patrocinador, sino un aliado estratégico que impulse el crecimiento del talento estudiantil y fortalezca el desarrollo tecnológico de México.
          </p>
        </div>
        <div>
          <h4 class="sigmar-ff text-xl mb-3 text-space-red dark:text-space-yellow">Vínculo Academia-Industria</h4>
          <p class="kanit-light text-base sm:text-lg leading-relaxed">
            El proyecto posiciona a las empresas como impulsoras del talento joven, brindando una plataforma de vinculación directa con la comunidad universitaria de la <a href="https://www.azc.uam.mx/" target="_blank"><strong>UAM Azcapotzalco</strong></a>.
          </p>
        </div>
      </div>
      
      <!-- Beneficios Clave -->
      <div>
        <h2 class="sigmar-ff text-3xl mb-8 text-space-red dark:text-space-yellow">Beneficios Clave</h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-8 gap-y-12 kanit-light text-lg sm:text-xl">
          <li class="flex items-start gap-4">
            <Eyes class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong class="kanit-regular text-space-red dark:text-space-yellow">Visibilidad de Marca:</strong><br/>
              Presencia de logotipos en el monoplaza OP01, uniformes y material promocional.
            </div>
          </li>
          <li class="flex items-start gap-4">
            <Mobile class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong class="kanit-regular text-space-red dark:text-space-yellow">Impacto Digital:</strong><br/>
              Difusión constante en plataformas sociales con un alcance de más de 10,000 visualizaciones.
            </div>
          </li>
          <li class="flex items-start gap-4">
            <Document class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong class="kanit-regular text-space-red dark:text-space-yellow">Beneficio Fiscal:</strong><br/>
              Entrega de comprobante fiscal deducible de impuestos mediante la colaboración con <a href="https://www.fundacionuam.org/" target="_blank"><strong>Fundación UAM</strong></a>.
            </div>
          </li>
          <li class="flex items-start gap-4">
            <Event class="w-8 h-8 shrink-0 mt-1" />
            <div>
              <strong class="kanit-regular text-space-red dark:text-space-yellow">Presencia en Eventos:</strong><br/>
              Exposición de la marca en actividades con la comunidad universitaria y exposiciones automotrices.
            </div>
          </li>
        </ul>
      </div>

      <div id="unete" class="bg-space-red/10 dark:bg-space-yellow/10 p-8 sm:p-12 rounded-3xl text-center border border-space-red/20 dark:border-space-yellow/20">
        <h2 class="sigmar-ff text-3xl sm:text-4xl mb-4 text-space-red dark:text-space-yellow">¡Únete al equipo!</h2>
        <p class="kanit-light text-lg sm:text-xl leading-relaxed mb-8 max-w-2xl mx-auto opacity-90">
          Buscamos construir relaciones de valor con cada uno de nuestros patrocinadores. Para conocer los montos y el retorno de inversión de cada nivel, descarga nuestro resumen de propuesta o contáctanos directamente.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href="#" class="button-link space-btn-outlined kanit-regular text-lg font-bold hover:scale-105 transition-transform px-8 py-3 flex items-center gap-3">
            <Pdf class="w-6 h-6 shrink-0" />
            Propuesta de Patrocinio
          </a>
        </div>
        <div class="mt-8 pt-8 border-t border-space-red/20 dark:border-white/10 flex flex-col sm:flex-row justify-center gap-6 sm:gap-12 kanit-light text-lg">
          <a href="mailto:uamotors.fsae@azc.uam.mx" class="flex items-center justify-center gap-2 hover:text-space-red dark:hover:text-space-yellow transition-colors group">
            <EmailIcon class="w-5 h-5" /> uamotors.fsae@azc.uam.mx
          </a>
        </div>
      </div>

    </section>

  </div>
</MainLayout>

<style is:global>
  /* Quitar redondeo global de las imágenes en las galerías de patrocinadores para no recortar los logos */
  #diamante-grid img,
  #carousel-oro img,
  #carousel-bronce-plata img {
    border-radius: 0 !important;
  }
</style>
