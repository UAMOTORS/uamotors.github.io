---
import siteConfig, { type Link } from "../site.config";
import Hamburger from "./Hamburger.astro";
import ThemeSwitcher from "./ThemeSwitcher.astro";
import SiteIdentity from "./SiteIdentity.astro";
import NavLinks from "./NavLinks.astro";
import CloseIcon from "../icons/Close.astro";
import { withBase } from "../utils/helpers";

const { activePage } = Astro.props;
const currentPath = Astro.url.pathname;
const isEnglish = currentPath.startsWith("/en") || currentPath.startsWith("/en/");
let targetUrl = "/";
if (isEnglish) {
  targetUrl = currentPath.replace(/^\/en(\/|$)/, "/");
} else {
  targetUrl = "/en" + (currentPath === "/" ? "" : currentPath);
}

const englishNavLinks = [
  {
    text: "About Us",
    href: withBase("/en/nosotros")
  },
  {
    text: "Project",
    href: withBase("/en/proyecto")
  },
  {
    text: "Our Partners",
    href: withBase("/en/nuestros-aliados")
  },
  {
    text: "Contact",
    href: withBase("/en/contacto")
  }
];

const navLinks = isEnglish ? englishNavLinks : siteConfig.headerNavLinks;
---

<header>
  <nav
    class="nav-glass font-light w-full flex flex-row items-center justify-between gap-2 rounded-4xl px-5 py-2 text-xs sm:gap-8 sm:py-3 sm:text-base"
  >
    <a id="nav-logo-link" href={withBase(isEnglish ? "/en" : "/")}><SiteIdentity /></a>
    <div class="hidden md:flex md:gap-8">
      {(<NavLinks activePage={activePage} links={navLinks} />)}
    </div>
    <div class="flex items-center gap-4">
      <a
        href={targetUrl}
        translate="no"
        class="notranslate flex items-center justify-center w-[38px] h-[38px] text-xs font-semibold rounded-full border border-gray-500/30 hover:border-space-red dark:hover:border-space-yellow hover:text-space-red dark:hover:text-space-yellow transition-colors cursor-pointer select-none"
      >
        {isEnglish ? "ES" : "EN"}
      </a>
      <ThemeSwitcher />
      <Hamburger />
    </div>
  </nav>
  <div
    id="mobile-links"
    class="font-light animated h-0 m-0 opacity-0 top-0 w-full pointer-events-none overflow-hidden flex flex-col"
  >
    <span class="close-menu cursor-pointer hover:text-space-red dark:hover:text-space-yellow transition-colors mb-4"><CloseIcon class="w-6 h-6" /></span>
    <NavLinks
      activePage={activePage}
      links={navLinks}
      isMobileLink={true}
    />

  </div>
</header>
<script>
  document.addEventListener('astro:page-load', () => {
    const hamburger = document.querySelector("#hamburger-menu");
    const mobileLinks = document.querySelector("#mobile-links");

    if (hamburger && mobileLinks) {
      if (!hamburger.dataset.listenerAttached) {
        hamburger.addEventListener("click", () => {
          mobileLinks.classList.remove("slideOutUp");
          mobileLinks.classList.add("expanded");
          mobileLinks.classList.add("slideInDown");
        });
        hamburger.dataset.listenerAttached = "true";
      }
    }

    const closeMenus = document.querySelectorAll(".close-menu");
    if (closeMenus.length > 0 && mobileLinks) {
      closeMenus.forEach(closeMenu => {
        if (!closeMenu.dataset.listenerAttached) {
          closeMenu.addEventListener("click", () => {
            mobileLinks.classList.add("slideOutUp");
            mobileLinks.classList.add("expanded");
            mobileLinks.classList.remove("slideInDown");
          });
          closeMenu.dataset.listenerAttached = "true";
        }
      });
    }
  });
</script>

<style>
  .nav-glass {
    background-color: var(--glass-bg) !important;
    backdrop-filter: var(--glass-blur) !important;
    -webkit-backdrop-filter: var(--glass-blur) !important;
    border: var(--glass-border) !important;
    box-shadow: var(--glass-shadow) !important;
    transform: translate3d(0, 0, 0) !important;
    backface-visibility: hidden !important;
    will-change: transform, backdrop-filter !important;
  }

  @media (orientation: portrait) {
    #mobile-links.expanded {
      align-items: end;
      background-color: var(--glass-bg) !important;
      backdrop-filter: var(--glass-blur) !important;
      -webkit-backdrop-filter: var(--glass-blur) !important;
      border-bottom: var(--glass-border) !important;
      box-shadow: var(--glass-shadow) !important;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      justify-content: end;
      position: absolute;
      pointer-events: auto;
      z-index: 10;
      opacity: 1;
      padding: 1rem 2rem;
      width: 100vw;
      top: 0;
      min-height: fit-content;
      border-bottom-left-radius: 1rem;
      border-bottom-right-radius: 1rem;
    }
  }
</style>
