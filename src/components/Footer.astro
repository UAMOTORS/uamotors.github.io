---
import siteConfig from "../site.config";
import SiteIdentity from "./SiteIdentity.astro";
import InstagramIcon from "../icons/social_media/Instagram.astro";
import FacebookIcon from "../icons/social_media/Facebook.astro";
import TiktokIcon from "../icons/social_media/Tiktok.astro";
import LinkedinIcon from "../icons/social_media/Linkedin.astro";

const currentYear = new Date().getFullYear();
---

<footer class="kanit-light text-xs sm:text-sm">
  <div
    class="footer-primary flex flex-col items-center justify-center min-w-full border-t border-gray-500/50"
  >
    <div
      class="flex flex-row items-center justify-around sm:justify-center gap-6 sm:gap-10 pt-8 pb-6 sm:px-6 text-center"
    >
      <a href="https://www.instagram.com/uamotors.fsae/" target="_blank" title="Instagram" class="hover:text-space-red dark:hover:text-space-yellow transition-colors hover:scale-110 transform duration-200">
        <InstagramIcon class="w-8 h-8 sm:w-10 sm:h-10" />
      </a>
      <a href="https://www.facebook.com/uamotors" target="_blank" title="Facebook" class="hover:text-space-red dark:hover:text-space-yellow transition-colors hover:scale-110 transform duration-200">
        <FacebookIcon class="w-8 h-8 sm:w-10 sm:h-10" />
      </a>
      <a href="https://www.tiktok.com/@uamotors.fsae" target="_blank" title="TikTok" class="hover:text-space-red dark:hover:text-space-yellow transition-colors hover:scale-110 transform duration-200">
        <TiktokIcon class="w-8 h-8 sm:w-10 sm:h-10" />
      </a>
      <a href="https://www.linkedin.com/company/uamotors/" target="_blank" title="LinkedIn" class="hover:text-space-red dark:hover:text-space-yellow transition-colors hover:scale-110 transform duration-200">
        <LinkedinIcon class="w-8 h-8 sm:w-10 sm:h-10" />
      </a>
    </div>
  </div>
  <div
    class="footer-secondary flex flex-col items-center justify-center gap-2 min-w-full pb-8"
  >
    <div class="flex flex-col gap-1 items-center justify-center text-balance opacity-80 text-center">
      <span>&copy; {currentYear} {siteConfig.title}. Todos los derechos reservados.</span>
      <span class="text-xs opacity-75 mt-1">
        Desarrollado por <a href="https://github.com/lexrammart" target="_blank" class="kanit-regular hover:text-space-red dark:hover:text-space-yellow transition-colors">Alejandro Ramírez</a> para UAMOTORS <span class="hidden sm:inline">|</span><br class="sm:hidden" />
        Basado en el tema <a href="https://github.com/djsiddz/space-ahead" target="_blank" class="kanit-regular hover:text-space-red dark:hover:text-space-yellow transition-colors">Space Ahead</a>.
      </span>
    </div>
  </div>
  <div
    class="footer-identity text-center overflow-hidden w-full sticky bottom-0 flex items-end justify-center"
  >
    <span
      class="sigmar-ff text-[16vw] sm:text-[6.5rem] leading-none text-whitesmoke/50 dark:text-gray-300/30"
      >{siteConfig.title}</span
    >
  </div>
</footer>
