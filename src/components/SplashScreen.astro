---
import TiraUamotors from "./logos/TiraUamotors.astro";
---

<div
  id="splash-screen"
  class="fixed inset-0 bg-black z-[100000] flex flex-col items-center justify-center transition-all duration-500 ease-in-out select-none pointer-events-none opacity-0 hidden"
>
  <div
    class="relative w-[75%] max-w-xs sm:max-w-md flex flex-col items-center justify-center"
  >
    <TiraUamotors
      useSweep={true}
      class="w-full h-auto text-white filter drop-shadow-[0_0_20px_rgba(255,255,255,0.22)] transform scale-95 opacity-0 animate-splash-logo"
    />
  </div>
</div>

<script is:inline>
  (function () {
    const splash = document.getElementById("splash-screen");
    if (!splash) return;

    const hasShown = sessionStorage.getItem('uamotors-splash-shown');
    if (hasShown) {
      splash.style.display = 'none';
      splash.style.opacity = '0';
    } else {
      document.documentElement.classList.add('splash-active');
      splash.style.display = 'flex';
      splash.getBoundingClientRect();
      splash.style.opacity = '1';
      splash.classList.remove('pointer-events-none');
      splash.classList.add('pointer-events-auto');

      setTimeout(() => {
        splash.style.opacity = '0';
        splash.style.transform = 'translateY(-15px)';
        splash.classList.add('pointer-events-none');
        splash.classList.remove('pointer-events-auto');
        
        setTimeout(() => {
          splash.style.display = 'none';
          document.documentElement.classList.remove('splash-active');
          sessionStorage.setItem('uamotors-splash-shown', 'true');
        }, 500);
      }, 1200);
    }
  })();
</script>

<style>
  @keyframes splashLogo {
    0% {
      opacity: 0;
      transform: scale(0.95);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .animate-splash-logo {
    animation: splashLogo 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
