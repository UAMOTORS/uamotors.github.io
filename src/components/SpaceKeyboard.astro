  "Understood, we are checking. — Ferrari Engineer",
  "It is a beautiful day, baby! Let's go! — Charles Leclerc",
  "Box, box, box! — Ingeniero de Carrera",
  "Leave me alone, I know what to do! — Kimi",
  "If you no longer go for a gap... — Ayrton Senna",
  "Smooth operatorrr... — Carlos Sainz",
  "Bono, my tyres are gone! — Lewis Hamilton",
  "No, no, no, Michael! That was so not right! — Toto Wolff",
  "Simply simply lovely. — Max Verstappen",
  "GP2 engine, GP2! — Fernando Alonso",
  "Karma! — Fernando Alonso",
  "To finish first, first you must finish. — Michael Schumacher",
  "It's lights out and away we go! — David Croft",
  "El segundo es el primero de los perdedores. — Ayrton Senna",
  "No me des más potencia, dame menos peso. — Colin Chapman",
  "Llevando la ingeniería mexicana al límite.",
  "Diseña con ingenio, crea con pasión. — UAMOTORS",
  "No es solo velocidad, es ingeniería. — UAMOTORS",
  "¡Bandera roja en pista! Dirección de carrera.",
  "¡Push, push! Vuelta rápida.",
  "¡Error 404: Fuera de la pista!",
  "El éxito se construye milésima a milésima.",
  "En la pista no hay suerte, solo preparación.",
  "No limit to what we can build. — UAMOTORS",
  "Feel the speed, respect the engineering. — UAMOTORS",
  "Maximum attack! Vuelta de clasificación.",
];

const defaultEnMessages = [
  "Just an inchident. — Charles Leclerc",
  "NOOOOOO! — Charles Leclerc, France 2022",
  "Monaco is ours! — Charles Leclerc, 2024",
  "I think we need to box. — Charles Leclerc",
  "Understood, we are checking. — Ferrari Engineer",
  "It is a beautiful day, baby! Let's go! — Charles Leclerc",
  "Box, box, box! — Race Engineer",
  "Leave me alone, I know what to do! — Kimi",
  "If you no longer go for a gap... — Ayrton Senna",
  "Smooth operatorrr... — Carlos Sainz",
  "Bono, my tyres are gone! — Lewis Hamilton",
  "No, no, no, Michael! That was so not right! — Toto Wolff",
  "Simply simply lovely. — Max Verstappen",
  "GP2 engine, GP2! — Fernando Alonso",
  "Karma! — Fernando Alonso",
  "To finish first, first you must finish. — Michael Schumacher",
  "It's lights out and away we go! — David Croft",
  "Second is the first of the losers. — Ayrton Senna",
  "Simplify, then add lightness. — Colin Chapman",
  "Pushing Mexican engineering to the limit.",
  "Design with ingenuity, create with passion. — UAMOTORS",
  "It's not just speed, it's engineering. — UAMOTORS",
  "Red flag on track! Race control.",
  "Push, push! Fastest lap.",
  "Error 404: Off track!",
  "Success is built thousandth by thousandth.",
  "On the track there is no luck, only preparation.",
  "No limit to what we can build. — UAMOTORS",
  "Feel the speed, respect the engineering. — UAMOTORS",
  "Maximum attack! Qualifying lap.",
];

const messages = customMessages || defaultMessages;
const enMessages = customEnMessages || defaultEnMessages;
---

<div
  class="flex flex-row w-full justify-between gap-2 items-center mt-12 sm:mt-24"
>
  <div
    id="ctrl-left"
    class="hidden sm:block pl-2 pb-2 pt-4 pr-4 text-xs border border-dashed border-gray-500 rounded-2xl font-mono"
  >
    ^
  </div>
  <div
    id="fn"
    class="hidden sm:block pl-2 pb-2 pt-4 pr-4 text-xs border border-dashed border-gray-500 rounded-2xl font-mono"
  >
    ⌥
  </div>
  <div
    id="alt-left"
    class="hidden sm:block pl-2 pb-2 pt-4 pr-4 text-xs border border-dashed border-gray-500 rounded-2xl font-mono"
  >
    ⌘
  </div>

  <button
    id="space-pop-culture"
    class="flex-grow w-full text-center pl-2 pb-2 pt-4 pr-4 text-xs border border-dashed border-gray-500 rounded-2xl font-mono cursor-pointer hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-200 whitespace-nowrap"
    title="¡Haz clic aquí!"
  >
    {messages[0]}
  </button>

  <div
    id="alt-right"
    class="hidden sm:block pl-2 pb-2 pt-4 pr-4 text-xs border border-dashed border-gray-500 rounded-2xl font-mono"
  >
    ^
  </div>
  <div
    id="ctrl-right"
    class="hidden sm:block pl-2 pb-2 pt-4 pr-4 text-xs border border-dashed border-gray-500 rounded-2xl font-mono"
  >
    ⌘
  </div>
</div>

<script is:inline define:vars={{ messages, enMessages }}>
  function setupKeyboard() {
    const spaceBtn = document.getElementById("space-pop-culture");
    if (!spaceBtn) return;

    const isEn = window.location.pathname.startsWith('/en/') || window.location.pathname === '/en';
    const activeMessages = isEn ? enMessages : messages;

    const platform = navigator.userAgent.toLowerCase();
    const isWin = platform.includes("win");

    const ctrlLeft = document.getElementById("ctrl-left");
    const ctrlRight = document.getElementById("ctrl-right");
    const altLeft = document.getElementById("alt-left");
    const altRight = document.getElementById("alt-right");
    const fnKey = document.getElementById("fn");

    if (isWin) {
      if (ctrlLeft) ctrlLeft.textContent = "ctrl";
      if (ctrlRight) ctrlRight.textContent = "ctrl";
      if (altLeft) altLeft.textContent = "alt";
      if (altRight) altRight.textContent = "alt";
      if (fnKey) fnKey.textContent = "fn";
    } else {
      if (ctrlLeft) ctrlLeft.textContent = "^";
      if (ctrlRight) ctrlRight.textContent = "⌘";
      if (altLeft) altLeft.textContent = "⌥";
      if (altRight) altRight.textContent = "^";
      if (fnKey) fnKey.textContent = "⌥";
    }

    spaceBtn.textContent = activeMessages[0];

    const getRandomMessage = () =>
      activeMessages[Math.floor(Math.random() * activeMessages.length)];

    const handleSpacebar = (e) => {
      if (
        e.code === "Space" &&
        e.target.tagName !== "INPUT" &&
        e.target.tagName !== "TEXTAREA"
      ) {
        e.preventDefault();
        spaceBtn.textContent = getRandomMessage();
      }
    };

    const handleClick = () => {
      spaceBtn.textContent = getRandomMessage();
    };

    window.addEventListener("keydown", handleSpacebar);
    spaceBtn.addEventListener("click", handleClick);

    return () => {
      window.removeEventListener("keydown", handleSpacebar);
    };
  }

  let cleanup;
  document.addEventListener("astro:page-load", () => {
    if (cleanup) cleanup();
    cleanup = setupKeyboard();
  });
</script>
