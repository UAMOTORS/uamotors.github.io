---
import type { HTMLAttributes } from "astro/types";
import logoSrc from "../../../assets/logos/silver/PrimeraPlus-logo.svg";

type Props = HTMLAttributes<"img">;
const { class: className, ...props } = Astro.props;
---

<img
  src={logoSrc.src}
  alt="Logo Primera Plus"
  class:list={[
    className,
    "transition-all duration-300 filter grayscale opacity-70 hover:grayscale-0 hover:opacity-100 hover:scale-105 dark:invert dark:opacity-60 dark:hover:invert-0 dark:hover:opacity-100",
  ]}
  {...props}
/>
